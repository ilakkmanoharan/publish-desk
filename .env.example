# --- Firebase (client: optional; server: required for Sync from GitHub) ---
# Optional: override Firebase client config (defaults in lib/firebase/config.ts)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Required for "Sync from GitHub" (Dashboard → Content source). Without this, sync returns 503.
# The JSON file on disk is not read automatically — this variable must point to it (no spaces around =).
# Restart `next dev` after changing .env. Deployed hosts (Vercel, etc.) do not include ./private — use FIREBASE_SERVICE_ACCOUNT_JSON there.
# Option A (recommended locally): path to service account JSON. Save key from Firebase Console → Project settings → Service accounts → Generate new key as private/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_PATH=./private/firebase-service-account.json
# Option B: stringified JSON instead of file (e.g. for Vercel). Use single quotes, escape any single quotes inside.
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
