# Optional: override Firebase client config (defaults are in lib/firebase/config.ts)
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# Required for "Sync from GitHub" (Dashboard → Content source). Without this, sync returns 503.
# Option A: path to service account JSON file (e.g. downloaded from Firebase Console → Project settings → Service accounts → Generate new key). Keep file in private/ (gitignored).
# FIREBASE_SERVICE_ACCOUNT_PATH=./private/firebase-service-account.json
# Option B: stringified JSON (use single quotes, escape any single quotes inside)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
