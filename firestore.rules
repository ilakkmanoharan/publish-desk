rules_version = '2';
// All user data is scoped by request.auth.uid; users can only read/write their own content, categories, tags, magazines, and publications.
service cloud.firestore {
  match /databases/{database}/documents {
    // Users: only their own profile (e.g. githubRepoUrl)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Categories: own data only
    match /categories/{id} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    // Tags: own data only
    match /tags/{id} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    // Content: owner can write; anyone can read (needed for public article pages)
    match /content/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Magazines: owner can write; everyone can read (for public listing)
    match /magazines/{id} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    // Publications: owner can write; anyone can read if status is Published (for public article pages)
    match /publications/{id} {
      allow read: if resource.data.status == "Published" || (request.auth != null && resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
