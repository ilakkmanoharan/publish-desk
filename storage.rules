rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/content/{contentId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Profile photo: signed-in owner only. Size is enforced in the app (PROFILE_AVATAR_MAX_BYTES);
    // Avoid request.resource.size here — some uploads omit it in rules evaluation and deny as unauthorized.
    match /users/{userId}/profile/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
